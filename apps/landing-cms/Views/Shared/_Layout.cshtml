@using LandingCms.Helpers
@model LandingPage
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    @* Canonical URL *@
    @if (!string.IsNullOrEmpty(Context.Request.Scheme) && !string.IsNullOrEmpty(Context.Request.Host.Value))
    {
        <link rel="canonical" href="@($"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}")" />
    }
    
    @* Robots meta *@
    <meta name="robots" content="index, follow" />
    
    @* SEO мета-теги из SeoRegion *@
    <title>@(Model?.Seo?.MetaTitle?.Value ?? "Платформа онлайн-обучения")</title>
    @if (!string.IsNullOrEmpty(Model?.Seo?.MetaDescription?.Value))
    {
        <meta name="description" content="@Model.Seo.MetaDescription.Value" />
    }
    @if (!string.IsNullOrEmpty(Model?.Seo?.MetaKeywords?.Value))
    {
        <meta name="keywords" content="@Model.Seo.MetaKeywords.Value" />
    }
    
    @* Open Graph теги для социальных сетей *@
    @if (!string.IsNullOrEmpty(Model?.Seo?.OgTitle?.Value))
    {
        <meta property="og:title" content="@Model.Seo.OgTitle.Value" />
    }
    @if (!string.IsNullOrEmpty(Model?.Seo?.OgDescription?.Value))
    {
        <meta property="og:description" content="@Model.Seo.OgDescription.Value" />
    }
    @if (Model?.Seo?.OgImage?.HasValue == true)
    {
        <meta property="og:image" content="@ImageHelper.GetImageUrl(Url, Model.Seo.OgImage.Id, 1200, 630)" />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
    }
    @if (!string.IsNullOrEmpty(Context.Request.Scheme) && !string.IsNullOrEmpty(Context.Request.Host.Value))
    {
        <meta property="og:url" content="@($"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}")" />
    }
    <meta property="og:type" content="website" />
    
    @* Twitter Card теги *@
    <meta name="twitter:card" content="summary_large_image" />
    @if (!string.IsNullOrEmpty(Model?.Seo?.OgTitle?.Value))
    {
        <meta name="twitter:title" content="@Model.Seo.OgTitle.Value" />
    }
    @if (!string.IsNullOrEmpty(Model?.Seo?.OgDescription?.Value))
    {
        <meta name="twitter:description" content="@Model.Seo.OgDescription.Value" />
    }
    @if (Model?.Seo?.OgImage?.HasValue == true)
    {
        <meta name="twitter:image" content="@ImageHelper.GetImageUrl(Url, Model.Seo.OgImage.Id, 1200, 630)" />
    }
    
    @* Structured Data (JSON-LD) *@
    <partial name="_StructuredData" model="Model" />
    
    @* Bootstrap 5 CSS *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold" href="/">Платформа онлайн-обучения</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Переключить навигацию">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="#about">О программе</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#tariffs">Тарифы</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary ms-lg-3" href="/app">Личный кабинет</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main">
        @RenderBody()
    </main>

    <footer class="bg-light py-4 mt-5">
        <div class="container text-center">
            <p class="mb-0">&copy; 2026 - Платформа онлайн-обучения</p>
        </div>
    </footer>

    @* Bootstrap 5 JS Bundle *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
