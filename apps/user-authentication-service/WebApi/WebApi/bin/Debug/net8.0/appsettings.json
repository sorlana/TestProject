{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=user_authentication_db;Username=postgres;Password=postgres",
    "Redis": "localhost:6379",
    "RabbitMQ": "amqp://guest:guest@localhost:5672"
  },
  "JwtSettings": {
    "SecretKey": "your-secret-key-min-32-characters-long-for-hs256",
    "Issuer": "UserAuthenticationService",
    "Audience": "UserAuthenticationServiceClients",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7,
    "RefreshTokenExpirationDaysRememberMe": 30
  },
  "GoogleOAuth": {
    "ClientId": "your-google-client-id.apps.googleusercontent.com",
    "ClientSecret": "your-google-client-secret"
  },
  "SmsProvider": {
    "Provider": "Twilio",
    "ApiKey": "your-sms-provider-api-key",
    "ApiUrl": "https://api.twilio.com/2010-04-01",
    "FromPhoneNumber": "+1234567890",
    "AccountSid": "your-twilio-account-sid"
  },
  "NopCommerceApi": {
    "BaseUrl": "https://shop.example.com/api",
    "ApiKey": "your-nopcommerce-api-key",
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "RetryDelaySeconds": 2
  },
  "RateLimiting": {
    "FailedLoginAttemptsPerUser": 5,
    "FailedLoginWindowMinutes": 15,
    "UserLockoutMinutes": 15,
    "FailedLoginAttemptsPerIp": 20,
    "IpLockoutHours": 1,
    "PhoneVerificationMaxAttemptsPerHour": 3
  },
  "CorsSettings": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "https://yourdomain.com"
    ],
    "AllowedMethods": [ "GET", "POST", "PUT", "DELETE" ],
    "AllowedHeaders": [ "Authorization", "Content-Type" ],
    "AllowCredentials": true
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] [{MachineName}] [{EnvironmentName}] [{ThreadId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/user-auth-service-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] [{MachineName}] [{EnvironmentName}] [{ThreadId}] {Message:lj}{NewLine}{Exception}",
          "shared": true
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithEnvironmentName", "WithThreadId" ],
    "Properties": {
      "Application": "UserAuthenticationService"
    }
  },
  "AllowedHosts": "*"
}
