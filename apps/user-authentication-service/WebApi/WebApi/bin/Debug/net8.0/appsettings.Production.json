{
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": "",
    "RabbitMQ": ""
  },
  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "UserAuthenticationService",
    "Audience": "UserAuthenticationServiceClients",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7,
    "RefreshTokenExpirationDaysRememberMe": 30
  },
  "GoogleOAuth": {
    "ClientId": "",
    "ClientSecret": ""
  },
  "SmsProvider": {
    "Provider": "Twilio",
    "ApiKey": "",
    "ApiUrl": "",
    "FromPhoneNumber": "",
    "AccountSid": ""
  },
  "NopCommerceApi": {
    "BaseUrl": "",
    "ApiKey": "",
    "TimeoutSeconds": 30,
    "RetryCount": 3,
    "RetryDelaySeconds": 2
  },
  "RateLimiting": {
    "FailedLoginAttemptsPerUser": 5,
    "FailedLoginWindowMinutes": 15,
    "UserLockoutMinutes": 15,
    "FailedLoginAttemptsPerIp": 20,
    "IpLockoutHours": 1,
    "PhoneVerificationMaxAttemptsPerHour": 3
  },
  "CorsSettings": {
    "AllowedOrigins": [],
    "AllowedMethods": [ "GET", "POST", "PUT", "DELETE" ],
    "AllowedHeaders": [ "Authorization", "Content-Type" ],
    "AllowCredentials": true
  },
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http1AndHttp2"
    },
    "Endpoints": {
      "Https": {
        "Url": "https://*:443",
        "Protocols": "Http1AndHttp2"
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Error",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] [{MachineName}] [{EnvironmentName}] [{ThreadId}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "/app/logs/user-auth-service-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 90,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] [{SourceContext}] [{MachineName}] [{EnvironmentName}] [{ThreadId}] {Message:lj}{NewLine}{Exception}",
          "shared": true
        }
      }
    ]
  }
}
