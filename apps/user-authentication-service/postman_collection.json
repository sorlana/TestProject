      ]
    },
    {
      "name": "Мониторинг",
      "item": [
        {
          "name": "Health Check - Полная проверка",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Проверка состояния сервиса и всех зависимостей (PostgreSQL, Redis, RabbitMQ)."
          },
          "response": []
        },
        {
          "name": "Health Check - Readiness",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health/ready",
              "host": ["{{base_url}}"],
              "path": ["health", "ready"]
            },
            "description": "Проверка готовности сервиса к обработке запросов (для Kubernetes readiness probe)."
          },
          "response": []
        },
        {
          "name": "Health Check - Liveness",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health/live",
              "host": ["{{base_url}}"],
              "path": ["health", "live"]
            },
            "description": "Проверка работоспособности процесса (для Kubernetes liveness probe)."
