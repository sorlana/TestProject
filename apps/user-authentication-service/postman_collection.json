                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/subscriptions/1",
              "host": ["{{base_url}}"],
              "path": ["api", "subscriptions", "1"]
            },
            "description": "Отмена подписки. Обновляет статус в nopCommerce."
          },
          "response": []
