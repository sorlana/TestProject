# Строки подключения к базам данных и сервисам
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=user_authentication_db;Username=postgres;Password=your_password
ConnectionStrings__Redis=localhost:6379
ConnectionStrings__RabbitMQ=amqp://guest:guest@localhost:5672

# Настройки JWT токенов
JwtSettings__SecretKey=your-secret-key-min-32-characters-long-for-hs256-algorithm
JwtSettings__Issuer=UserAuthenticationService
JwtSettings__Audience=UserAuthenticationServiceClients
JwtSettings__AccessTokenExpirationMinutes=15
JwtSettings__RefreshTokenExpirationDays=7
JwtSettings__RefreshTokenExpirationDaysRememberMe=30

# Настройки Google OAuth
GoogleOAuth__ClientId=your-google-client-id.apps.googleusercontent.com
GoogleOAuth__ClientSecret=your-google-client-secret

# Настройки SMS провайдера (Twilio)
SmsProvider__Provider=Twilio
SmsProvider__ApiKey=your-twilio-api-key
SmsProvider__ApiUrl=https://api.twilio.com/2010-04-01
SmsProvider__FromPhoneNumber=+1234567890
SmsProvider__AccountSid=your-twilio-account-sid

# Настройки внешнего nopCommerce API
NopCommerceApi__BaseUrl=https://shop.example.com/api
NopCommerceApi__ApiKey=your-nopcommerce-api-key
NopCommerceApi__TimeoutSeconds=30
NopCommerceApi__RetryCount=3
NopCommerceApi__RetryDelaySeconds=2

# Настройки CORS
CorsSettings__AllowedOrigins__0=http://localhost:3000
CorsSettings__AllowedOrigins__1=http://localhost:5173
CorsSettings__AllowedOrigins__2=https://yourdomain.com

# Настройки Rate Limiting
RateLimiting__FailedLoginAttemptsPerUser=5
RateLimiting__FailedLoginWindowMinutes=15
RateLimiting__UserLockoutMinutes=15
RateLimiting__FailedLoginAttemptsPerIp=20
RateLimiting__IpLockoutHours=1
RateLimiting__PhoneVerificationMaxAttemptsPerHour=3

# Настройки ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=https://+:443;http://+:80
