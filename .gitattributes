# Line endings settings
* text=auto

# Text files with LF
*.cs text eol=lf
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.html text eol=lf
*.css text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.sql text eol=lf
*.sh text eol=lf
Dockerfile* text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
Makefile text eol=lf

# Windows files with CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# PowerShell files
*.ps1 text eol=lf
*.psm1 text eol=lf
*.psd1 text eol=lf

# .NET files
*.csproj text eol=lf
*.sln text eol=lf
*.vcxproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.resx text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
*.zip binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary