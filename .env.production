# ============= ПРОДАКШЕН НАСТРОЙКИ =============
NODE_ENV=Production
APP_PORT=8080
LOG_LEVEL=Warning

# База данных Yandex Cloud
DB_HOST=c9qXXXXX.mdb.yandexcloud.net
DB_PORT=6432
DB_NAME=prod_db
DB_USER=prod_user
DB_PASSWORD=PROD_SECURE_PASSWORD
SSL_MODE=Require
SSL_CA_PATH=/certs/yandex-ca.pem

# Безопасность
JWT_SECRET=REAL_SUPER_SECRET_KEY_CHANGE_IN_PRODUCTION
CORS_ORIGIN=https://production-domain.com
FEATURE_SWAGGER_ENABLED=false
FEATURE_METRICS_ENABLED=true