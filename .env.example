# ============= НАСТРОЙКИ ПРОЕКТА =============
PROJECT_NAME=TestProject
COMPOSE_PROJECT_NAME=testproject

# ============= ОСНОВНЫЕ НАСТРОЙКИ =============
NODE_ENV=development
APP_PORT=4000
LOG_LEVEL=info
API_PREFIX=/api/v1

# ============= БАЗА ДАННЫХ (ЛОКАЛЬНАЯ) =============
DB_HOST=postgres-test
DB_PORT=5432
DB_NAME=testdb
DB_USER=test_user
DB_PASSWORD=test123

# ============= БАЗА ДАННЫХ (YANDEX CLOUD - ДЛЯ БУДУЩЕГО) =============
YC_DB_HOST=c9qXXXXX.mdb.yandexcloud.net
YC_DB_PORT=6432
YC_DB_NAME=testdb
YC_DB_USER=test_service
YC_DB_PASSWORD=YANDEX_CLOUD_PASSWORD_HERE

# ============= REDIS =============
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ============= PGADMIN =============
PGADMIN_PORT=8080
PGADMIN_EMAIL=admin@testproject.com
PGADMIN_PASSWORD=admin123

# ============= БЕЗОПАСНОСТЬ =============
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:4000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ============= ДЛЯ РАЗРАБОТКИ =============
DEBUG=test-service:*
NODE_OPTIONS=--max-old-space-size=512

# ============= НАСТРОЙКИ ПРИЛОЖЕНИЯ =============
LESSONS_PER_PAGE=20
COURSES_PER_PAGE=10

# ============= KUBERNETES (ЛОКАЛЬНО) =============
K8S_NAMESPACE=testproject-namespace
K8S_REGISTRY=localhost:5000
K8S_IMAGE_TAG=latest

# ============= SSL (ДЛЯ YANDEX CLOUD) =============
SSL_MODE=disable
SSL_CA_PATH=/certs/yandex-ca.pem

# ============= БЭКАПЫ =============
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7