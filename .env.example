# ============= НАСТРОЙКИ ПРОЕКТА =============
PROJECT_NAME=TestProject
COMPOSE_PROJECT_NAME=testproject

# ============= ОСНОВНЫЕ НАСТРОЙКИ =============
NODE_ENV=development
APP_PORT=4000
LANDING_CMS_PORT=3000
LOG_LEVEL=info
API_PREFIX=/api/v1

# ============= БАЗА ДАННЫХ (ЛОКАЛЬНАЯ) =============
DB_HOST=postgres-test
DB_PORT=5432
DB_NAME=testdb
DB_USER=test_user
DB_PASSWORD=test123

# ============= БАЗА ДАННЫХ (YANDEX CLOUD - ДЛЯ БУДУЩЕГО) =============
YC_DB_HOST=c9qXXXXX.mdb.yandexcloud.net
YC_DB_PORT=6432
YC_DB_NAME=testdb
YC_DB_USER=test_service
YC_DB_PASSWORD=YANDEX_CLOUD_PASSWORD_HERE

# ============= REDIS =============
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# ============= PGADMIN =============
PGADMIN_PORT=8080
PGADMIN_EMAIL=admin@testproject.com
PGADMIN_PASSWORD=admin123

# ============= БЕЗОПАСНОСТЬ =============
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:4000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ============= ДЛЯ РАЗРАБОТКИ =============
DEBUG=test-service:*
NODE_OPTIONS=--max-old-space-size=512

# ============= НАСТРОЙКИ ПРИЛОЖЕНИЯ =============
LESSONS_PER_PAGE=20
COURSES_PER_PAGE=10

# ============= LANDING CMS (PIRANHA CMS) =============
PIRANHA_MEDIA_CDN=

# ============= USER AUTHENTICATION SERVICE =============
AUTH_SERVICE_PORT=8081
AUTH_DB_NAME=auth_db
AUTH_REDIS_DB=1

# JWT настройки для Auth Service
JWT_ISSUER=UserAuthService
JWT_AUDIENCE=UserAuthServiceClient
JWT_ACCESS_TOKEN_EXPIRATION=15
JWT_REFRESH_TOKEN_EXPIRATION=7
JWT_REFRESH_TOKEN_EXPIRATION_REMEMBER_ME=30

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Yandex OAuth
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret

# SMS провайдер
SMS_PROVIDER_API_KEY=your_sms_provider_api_key_here
SMS_PROVIDER_API_URL=https://api.sms-provider.com/v1
SMS_PROVIDER_SENDER_NAME=AuthService

# nopCommerce интеграция
NOPCOMMERCE_BASE_URL=https://shop.example.com/api
NOPCOMMERCE_API_KEY=your_nopcommerce_api_key_here
NOPCOMMERCE_TIMEOUT=30
NOPCOMMERCE_RETRY_COUNT=3

# Rate Limiting для Auth Service
RATE_LIMIT_USER_ATTEMPTS=5
RATE_LIMIT_USER_WINDOW=15
RATE_LIMIT_USER_LOCKOUT=15
RATE_LIMIT_IP_ATTEMPTS=20
RATE_LIMIT_IP_WINDOW=60
RATE_LIMIT_IP_LOCKOUT=60

# Подтверждение телефона
PHONE_CODE_LENGTH=6
PHONE_CODE_EXPIRATION=10
PHONE_MAX_SENDS_PER_HOUR=3

# Подтверждение email
EMAIL_VERIFICATION_ENABLED=true
EMAIL_CODE_LENGTH=6
EMAIL_CODE_EXPIRATION=10
EMAIL_MAX_SENDS_PER_HOUR=3

# RabbitMQ
RMQ_HOST=rabbitmq
RMQ_PORT=5672
RMQ_VHOST=/
RMQ_LOGIN=guest
RMQ_PASSWORD=guest

# ============= KUBERNETES (ЛОКАЛЬНО) =============
K8S_NAMESPACE=testproject-namespace
K8S_REGISTRY=localhost:5000
K8S_IMAGE_TAG=latest

# ============= SSL (ДЛЯ YANDEX CLOUD) =============
SSL_MODE=disable
SSL_CA_PATH=/certs/yandex-ca.pem

# ============= БЭКАПЫ =============
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7