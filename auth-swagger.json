{
  "openapi": "3.0.1",
  "info": {
    "title": "API микросервиса аутентификации пользователей",
    "description": "REST API для регистрации, аутентификации и управления пользователями",
    "contact": {
      "name": "Команда разработки",
      "email": "support@example.com"
    },
    "version": "v1"
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Регистрация нового пользователя",
        "requestBody": {
          "description": "Данные для регистрации",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequestModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequestModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequestModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Регистрация успешна",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationResult"
                }
              }
            }
          },
          "400": {
            "description": "Ошибка валидации данных",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Вход в систему по логину и паролю",
        "requestBody": {
          "description": "Данные для входа",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequestModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Вход выполнен успешно",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationResult"
                }
              }
            }
          },
          "400": {
            "description": "Ошибка валидации данных",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Неверные учетные данные",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/google": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Вход через Google OAuth",
        "requestBody": {
          "description": "Google ID токен",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleAuthRequestModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleAuthRequestModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/GoogleAuthRequestModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Вход выполнен успешно",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationResult"
                }
              }
            }
          },
          "400": {
            "description": "Ошибка валидации токена",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Неверный Google токен",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Обновление JWT токена через refresh токен",
        "requestBody": {
          "description": "Refresh токен",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenRequestModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenRequestModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenRequestModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Токены обновлены успешно",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthenticationResult"
                }
              }
            }
          },
          "400": {
            "description": "Ошибка валидации",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Неверный или истекший refresh токен",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "summary": "Выход из системы",
        "responses": {
          "200": {
            "description": "Выход выполнен успешно"
          },
          "401": {
            "description": "Пользователь не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/password/generate": {
      "get": {
        "tags": [
          "Password"
        ],
        "summary": "Генерация надежного пароля",
        "responses": {
          "200": {
            "description": "Пароль сгенерирован успешно"
          }
        }
      }
    },
    "/api/phone/send-code": {
      "post": {
        "tags": [
          "PhoneVerification"
        ],
        "summary": "Отправка кода подтверждения на телефон",
        "requestBody": {
          "description": "Номер телефона",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendCodeRequestModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SendCodeRequestModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SendCodeRequestModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Код отправлен успешно"
          },
          "400": {
            "description": "Ошибка валидации или превышен лимит отправок",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/phone/verify": {
      "post": {
        "tags": [
          "PhoneVerification"
        ],
        "summary": "Проверка кода подтверждения",
        "requestBody": {
          "description": "Номер телефона и код подтверждения",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyCodeRequestModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyCodeRequestModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/VerifyCodeRequestModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Код подтвержден успешно"
          },
          "400": {
            "description": "Неверный или истекший код",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/phone/resend-code": {
      "post": {
        "tags": [
          "PhoneVerification"
        ],
        "summary": "Повторная отправка кода подтверждения",
        "requestBody": {
          "description": "Номер телефона",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SendCodeRequestModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SendCodeRequestModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SendCodeRequestModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Код отправлен успешно"
          },
          "400": {
            "description": "Ошибка валидации или превышен лимит отправок",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/subscriptions": {
      "get": {
        "tags": [
          "Subscription"
        ],
        "summary": "Получение подписок текущего пользователя",
        "responses": {
          "200": {
            "description": "Подписки получены успешно",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/UserSubscriptionDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Пользователь не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Subscription"
        ],
        "summary": "Оформление подписки",
        "requestBody": {
          "description": "Идентификатор плана подписки",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscribeRequestModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/SubscribeRequestModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/SubscribeRequestModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Подписка оформлена успешно"
          },
          "400": {
            "description": "Ошибка при оформлении подписки",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Пользователь не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/subscriptions/plans": {
      "get": {
        "tags": [
          "Subscription"
        ],
        "summary": "Получение доступных планов подписок",
        "responses": {
          "200": {
            "description": "Планы получены успешно",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SubscriptionPlanDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/subscriptions/{id}": {
      "delete": {
        "tags": [
          "Subscription"
        ],
        "summary": "Отмена подписки",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Идентификатор подписки",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Подписка отменена успешно"
          },
          "400": {
            "description": "Ошибка при отмене подписки",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Пользователь не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Подписка не найдена",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/profile": {
      "get": {
        "tags": [
          "UserProfile"
        ],
        "summary": "Получение профиля текущего пользователя",
        "responses": {
          "200": {
            "description": "Профиль получен успешно",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserProfileDto"
                }
              }
            }
          },
          "401": {
            "description": "Пользователь не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Профиль не найден",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "put": {
        "tags": [
          "UserProfile"
        ],
        "summary": "Обновление профиля текущего пользователя",
        "requestBody": {
          "description": "Данные для обновления",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileRequestModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileRequestModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileRequestModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Профиль обновлен успешно"
          },
          "400": {
            "description": "Ошибка валидации данных",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Пользователь не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "UserProfile"
        ],
        "summary": "Удаление аккаунта текущего пользователя (мягкое удаление)",
        "responses": {
          "200": {
            "description": "Аккаунт удален успешно"
          },
          "400": {
            "description": "Ошибка при удалении",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Пользователь не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/profile/password": {
      "put": {
        "tags": [
          "UserProfile"
        ],
        "summary": "Смена пароля текущего пользователя",
        "requestBody": {
          "description": "Данные для смены пароля",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequestModel"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequestModel"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ChangePasswordRequestModel"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Пароль изменен успешно"
          },
          "400": {
            "description": "Ошибка валидации или неверный текущий пароль",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Пользователь не авторизован",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthenticationResult": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "accessToken": {
            "type": "string",
            "nullable": true
          },
          "refreshToken": {
            "type": "string",
            "nullable": true
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "user": {
            "$ref": "#/components/schemas/UserDto"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "requiresPhoneVerification": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "ChangePasswordRequestModel": {
        "required": [
          "confirmNewPassword",
          "currentPassword",
          "newPassword"
        ],
        "type": "object",
        "properties": {
          "currentPassword": {
            "minLength": 1,
            "type": "string",
            "description": "Текущий пароль"
          },
          "newPassword": {
            "maxLength": 100,
            "minLength": 8,
            "type": "string",
            "description": "Новый пароль"
          },
          "confirmNewPassword": {
            "minLength": 1,
            "type": "string",
            "description": "Подтверждение нового пароля"
          }
        },
        "additionalProperties": false,
        "description": "Модель запроса смены пароля с валидацией"
      },
      "GoogleAuthRequestModel": {
        "required": [
          "idToken"
        ],
        "type": "object",
        "properties": {
          "idToken": {
            "minLength": 1,
            "type": "string",
            "description": "Google ID токен"
          }
        },
        "additionalProperties": false,
        "description": "Модель запроса Google аутентификации с валидацией"
      },
      "LoginRequestModel": {
        "required": [
          "password",
          "userName"
        ],
        "type": "object",
        "properties": {
          "userName": {
            "minLength": 1,
            "type": "string",
            "description": "Логин пользователя"
          },
          "password": {
            "minLength": 1,
            "type": "string",
            "description": "Пароль"
          },
          "rememberMe": {
            "type": "boolean",
            "description": "Флаг \"Запомнить меня\""
          }
        },
        "additionalProperties": false,
        "description": "Модель запроса входа с валидацией"
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": { }
      },
      "RefreshTokenRequestModel": {
        "required": [
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "refreshToken": {
            "minLength": 1,
            "type": "string",
            "description": "Refresh токен"
          }
        },
        "additionalProperties": false,
        "description": "Модель запроса обновления токена с валидацией"
      },
      "RegisterRequestModel": {
        "required": [
          "confirmPassword",
          "email",
          "password",
          "phoneNumber",
          "userName"
        ],
        "type": "object",
        "properties": {
          "userName": {
            "maxLength": 50,
            "minLength": 3,
            "type": "string",
            "description": "Логин пользователя"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "description": "Email адрес",
            "format": "email"
          },
          "phoneNumber": {
            "minLength": 1,
            "type": "string",
            "description": "Номер телефона",
            "format": "tel"
          },
          "password": {
            "maxLength": 100,
            "minLength": 8,
            "type": "string",
            "description": "Пароль"
          },
          "confirmPassword": {
            "minLength": 1,
            "type": "string",
            "description": "Подтверждение пароля"
          },
          "firstName": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string",
            "description": "Имя (необязательное поле)",
            "nullable": true
          },
          "lastName": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string",
            "description": "Фамилия (необязательное поле)",
            "nullable": true
          },
          "middleName": {
            "maxLength": 50,
            "minLength": 0,
            "type": "string",
            "description": "Отчество (необязательное поле)",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Модель запроса регистрации с валидацией"
      },
      "SendCodeRequestModel": {
        "required": [
          "phoneNumber"
        ],
        "type": "object",
        "properties": {
          "phoneNumber": {
            "minLength": 1,
            "type": "string",
            "description": "Номер телефона",
            "format": "tel"
          }
        },
        "additionalProperties": false,
        "description": "Модель запроса отправки кода с валидацией"
      },
      "SubscribeRequestModel": {
        "required": [
          "planId"
